1. ultrasonic_node.py 생성
  
  패키지 위치로 이동합니다.
  cd ~/yahboomcar_ros2_ws/yahboomcar_ws/src/auto_drive/auto_drive

새 파일 생성
  nano ultrasonic_node.py

아래 코드를 그대로 넣습니다.

#!/usr/bin/env python3

import time

import Jetson.GPIO as GPIO

import rclpy
from rclpy.node import Node

from std_msgs.msg import Float32


TRIG = 31
ECHO = 15


class UltrasonicNode(Node):

    def __init__(self):
        super().__init__('ultrasonic_node')

        GPIO.setmode(GPIO.BOARD)

        GPIO.setup(TRIG, GPIO.OUT)
        GPIO.setup(ECHO, GPIO.IN)

        GPIO.output(TRIG, False)

        self.publisher = self.create_publisher(
            Float32,
            '/ultrasonic_distance',
            10
        )

        self.timer = self.create_timer(
            0.05,
            self.publish_distance
        )

        self.get_logger().info("Ultrasonic Node Started")


    def measure(self):

        GPIO.output(TRIG, True)
        time.sleep(0.00001)
        GPIO.output(TRIG, False)

        timeout = time.time()

        while GPIO.input(ECHO) == 0:
            pulse_start = time.time()
            if time.time() - timeout > 0.03:
                return -1

        timeout = time.time()

        while GPIO.input(ECHO) == 1:
            pulse_end = time.time()
            if time.time() - timeout > 0.03:
                return -1

        pulse_duration = pulse_end - pulse_start

        distance = pulse_duration * 17150

        return round(distance, 2)


    def publish_distance(self):

        distance = self.measure()

        if distance > 0:

            msg = Float32()

            msg.data = distance

            self.publisher.publish(msg)

            self.get_logger().info(
                f"{distance:.1f} cm"
            )


def main():

    rclpy.init()

    node = UltrasonicNode()

    rclpy.spin(node)

    GPIO.cleanup()

    node.destroy_node()

    rclpy.shutdown()


if __name__ == "__main__":
    main()


2. 실행 권한
  chmod +x ultrasonic_node.py

3. setup.py 수정

기존

entry_points={
    'console_scripts':[
        ...
    ],
},

여기에
'ultrasonic_node = auto_drive.ultrasonic_node:main',
추가

예시

entry_points={
    'console_scripts':[
        'auto_drive=auto_drive.auto_drive:main',
        'ultrasonic_node=auto_drive.ultrasonic_node:main',
    ],
},


4. package.xml
  수정할 필요는 거의 없지만
  
  혹시 std_msgs가 없다면
  
  <depend>std_msgs</depend>
  
  추가합니다.
대부분 이미 들어있습니다.

5. 빌드
cd ~/yahboomcar_ros2_ws/yahboomcar_ws
colcon build --packages-select auto_drive
source install/setup.bash

6. 실행
새 터미널

ros2 run auto_drive ultrasonic_node

정상이라면

Ultrasonic Node Started
18.5 cm
18.4 cm
18.4 cm
18.5 cm
처럼 출력됩니다.

7. Topic 확인

다른 터미널
  ros2 topic echo /ultrasonic_distance

정상이라면
  data: 18.41
  data: 18.38 
  data: 18.45
  처럼 출력됩니다.
