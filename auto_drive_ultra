초음파를 별도 ROS2 노드로 만들고, 
auto_drive.py가 그 값을 받아서 정지 조건으로 쓰는 방식으로 진행하면 된다.
auto_drive.py가 실제 주행 명령을 내리는 파일이고, 
차선 유지 중 __set_current_speed()로 속도와 방향을 결정하는 구조라 
여기에 초음파 정지 조건을 넣는다.

진행순서
1. 초음파 ROS2 노드 만들기
cd ~/yahboomcar_ros2_ws/yahboomcar_ws/src/auto_drive/test
nano ultrasonic_node.py
==============
내용은 ultrasonic_test.py를 ROS2 토픽 발행 형태로 바꾼다.
==============
import rclpy
from rclpy.node import Node
from std_msgs.msg import Float32
import Jetson.GPIO as GPIO
import time

TRIG = 31
ECHO = 15

class UltrasonicNode(Node):
    def __init__(self):
        super().__init__('ultrasonic_node')
        self.pub = self.create_publisher(Float32, '/ultrasonic_distance', 10)

        GPIO.setwarnings(False)
        GPIO.setmode(GPIO.BOARD)
        GPIO.setup(TRIG, GPIO.OUT, initial=GPIO.LOW)
        GPIO.setup(ECHO, GPIO.IN)

        self.timer = self.create_timer(0.2, self.timer_callback)

    def measure_distance(self):
        GPIO.output(TRIG, GPIO.LOW)
        time.sleep(0.000002)

        GPIO.output(TRIG, GPIO.HIGH)
        time.sleep(0.00001)
        GPIO.output(TRIG, GPIO.LOW)

        timeout = time.time() + 0.03
        while GPIO.input(ECHO) == 0:
            start = time.time()
            if time.time() > timeout:
                return -1.0

        timeout = time.time() + 0.03
        while GPIO.input(ECHO) == 1:
            end = time.time()
            if time.time() > timeout:
                return -1.0

        distance = (end - start) * 34300 / 2
        return float(round(distance, 2))

    def timer_callback(self):
        msg = Float32()
        msg.data = self.measure_distance()
        self.pub.publish(msg)
        self.get_logger().info(f'ultrasonic: {msg.data} cm')

    def destroy_node(self):
        GPIO.cleanup()
        super().destroy_node()

def main():
    rclpy.init()
    node = UltrasonicNode()
    try:
        rclpy.spin(node)
    finally:
        node.destroy_node()
        rclpy.shutdown()

if __name__ == '__main__':
    main()
