상단 import에 추가.
from std_msgs.msg import Float32


__init__ 안에 추가.
self.ultrasonic_distance = -1.0
self.obstacle_stop_distance = 20.0
self.obstacle_detected = False

self.create_subscription(
    Float32,
    '/ultrasonic_distance',
    self.ultrasonic_callback,
    10
)

클래스 안에 함수 추가
def ultrasonic_callback(self, msg):
    self.ultrasonic_distance = msg.data

    if 0 < self.ultrasonic_distance <= self.obstacle_stop_distance:
        self.obstacle_detected = True
    else:
        self.obstacle_detected = False

3. 차선 주행 명령보다 먼저 정지 조건 넣기

자료상 차선 유지 처리는 __handle_lane_detect_result()에서 하고, 
그 안에서 __set_current_speed()로 속도와 각속도를 넣는다. 
여기에 초음파 우선 정지 조건을 넣으면 된다.

__handle_lane_detect_result() 함수 안에서 차선 계산 후 속도 명령이 나오기 전에 아래 코드를 넣는다.

if self.obstacle_detected:
    self.__set_current_speed(linear_x=0.0, angular_z=0.0)
    cv2.putText(
        frame,
        f"Obstacle: {self.ultrasonic_distance:.1f} cm",
        (10, 120),
        cv2.FONT_HERSHEY_SIMPLEX,
        0.8,
        (0, 0, 255),
        2
    )
    return frame

